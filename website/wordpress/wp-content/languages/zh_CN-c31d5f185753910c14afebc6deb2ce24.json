ece Google \u4e0b\u8f7d\u5e76\u5b58\u50a8\u5728\u60a8\u7684\u7f51\u7ad9\u4e0a\u3002\u7136\u540e\uff0c\u60a8\u7684\u7f51\u7ad9\u5c06\u4f7f\u7528\u8fd9\u4e9b\u672c\u5730\u6258\u7ba1\u7684\u5b57\u4f53\u3002"],"You can alternatively upload files directly on the Upload tab.":["\u60a8\u4e5f\u53ef\u4ee5\u76f4\u63a5\u5728\u300c\u4e0a\u4f20\u300d\u9009\u9879\u5361\u4e0a\u4f20\u6587\u4ef6\u3002"],"Allow access to Google Fonts":["\u5141\u8bb8\u8bbf\u95ee Google Fonts"],"Select font variants to install.":["\u9009\u62e9\u8981\u5b89\u88c5\u7684\u5b57\u4f53\u53d8\u4f53\u3002"],"Font name\u2026":["\u5b57\u4f53\u540d\u79f0\u2026"],"No fonts found. Try with a different search term":["\u672a\u627e\u5230\u5b57\u4f53\u3002\u5c1d\u8bd5\u4f7f\u7528\u4e0d\u540c\u7684\u641c\u7d22\u8bcd"],"Upload font":["\u4e0a\u4f20\u5b57\u4f53"],"Install Fonts":["\u5b89\u88c5\u5b57\u4f53"],"Fonts":["\u5b57\u4f53"],"Manage fonts":["\u7ba1\u7406\u5b57\u4f53"],"Reset the styles to the theme defaults":["\u5c06\u6837\u5f0f\u91cd\u7f6e\u4e3a\u4e3b\u9898\u9ed8\u8ba4\u503c"],"Default styles":["\u9ed8\u8ba4\u6837\u5f0f"],"Customize CSS":["\u81ea\u5b9a\u4e49 CSS"],"Style revisions":["\u6837\u5f0f\u4fee\u8ba2"],"Empty template part":["\u7a7a\u6a21\u677f\u7ec4\u4ef6"],"Style Revisions":["\u6837\u5f0f\u4fee\u6539"],"Deselect item: %s":["\u53d6\u6d88\u9009\u62e9\u9879\u76ee\uff1a%s"],"Select item: %s":["\u9009\u62e9\u9879\u76ee\uff1a%s"],"Select a new item":["\u9009\u62e9\u65b0\u9879\u76ee"],"Deselect item":["\u53d6\u6d88\u9009\u62e9\u9879\u76ee"],"Edit %d item":["\u7f16\u8f91 %d \u9879\u76ee"],"Bulk edit":["\u6279\u91cf\u7f16\u8f91"],"Add filter":["\u6dfb\u52a0\u8fc7\u6ee4\u5668"],"Deselect all":["\u53d6\u6d88\u5168\u90e8\u9009\u62e9"],"No results":["\u65e0\u7ed3\u679c"],"Is":["\u662f"],"Is not":["\u4e0d\u662f"],"Sort ascending":["\u5347\u5e8f\u6392\u5e8f"],"Sort descending":["\u964d\u5e8f\u6392\u5e8f"],"Activating %s":["\u542f\u7528 %s"],"Activate %s & Save":["\u542f\u7528 %s \u5e76\u4fdd\u5b58"],"Activate %s":["\u542